#!/usr/bin/env bash
# Forces "hyprctl dispatch dpms on" when a logind graphical session for this
# user transitions inactive -> active (VT switch back, resume from suspend,
# lid open).
#
# Why this exists: hypridle's on-resume only fires on Wayland input
# events, so a long idle + VT switch leaves the compositor stuck in
# dpms-off with no trigger to recover. logind owns the real
# session-active signal, so we listen there.

set -euo pipefail

XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

log() { printf '[dpms-on-session-active] %s\n' "$*" >&2; }

find_graphical_session_path() {
  local s type path
  while read -r s; do
    type=$(loginctl show-session "$s" -p Type --value 2> /dev/null || true)
    [[ "$type" == "wayland" || "$type" == "x11" ]] || continue
    path=$(busctl --system call org.freedesktop.login1 /org/freedesktop/login1 \
      org.freedesktop.login1.Manager GetSession s "$s" 2> /dev/null |
      awk '{gsub(/"/, "", $2); print $2}')
    if [[ -n "$path" ]]; then
      echo "$path"
      return 0
    fi
  done < <(loginctl list-sessions --no-legend | awk -v u="$USER" '$3==u {print $1}')
  return 1
}

session_active() {
  local path="$1"
  busctl --system get-property org.freedesktop.login1 "$path" \
    org.freedesktop.login1.Session Active 2> /dev/null |
    awk '{print $2}'
}

is_own_graphical_session() {
  local path="$1" uid type
  uid=$(busctl --system get-property org.freedesktop.login1 "$path" \
    org.freedesktop.login1.Session User 2> /dev/null |
    awk '{print $2}') || return 1
  [[ "$uid" == "$(id -u)" ]] || return 1

  type=$(busctl --system get-property org.freedesktop.login1 "$path" \
    org.freedesktop.login1.Session Type 2> /dev/null |
    awk -F'"' '{print $2}') || return 1
  [[ "$type" == "wayland" || "$type" == "x11" ]]
}

wake_hypr() {
  local sig
  # shellcheck disable=SC2012  # ls -t for newest entry; Hyprland instance signatures are hex, no non-alphanumeric concern.
  sig=$(ls -t "$XDG_RUNTIME_DIR/hypr" 2> /dev/null | head -1) || return 0
  [[ -n "$sig" ]] || return 0
  export HYPRLAND_INSTANCE_SIGNATURE="$sig"
  # The logind Active=true edge can precede Hyprland's DRM-resume completion on
  # VT switch-in: Hyprland reacquires the DRM master and replays its resume
  # (rechecks connectors, reassigns CRTCs), re-committing the prior monitor
  # power state. A single dispatch landing mid-resume gets clobbered back to off.
  # So dispatch + verify dpmsStatus, retrying until all monitors report on
  # (~4s timeout). dpms on is idempotent, so repeated dispatches are harmless.
  for _ in $(seq 1 12); do
    hyprctl dispatch dpms on > /dev/null 2>&1 || true
    if hyprctl monitors -j 2> /dev/null | jq -e 'length > 0 and all(.[]; .dpmsStatus == true)' > /dev/null 2>&1; then
      return 0
    fi
    sleep 0.35
  done
  log "warning: monitors still report dpms off after retries"
}

main() {
  local path active
  declare -A prev_active_by_path=()

  if path=$(find_graphical_session_path); then
    active=$(session_active "$path" || true)
    [[ -n "$active" ]] && prev_active_by_path["$path"]="$active"
    log "watching login1 sessions; initial graphical session $path Active=${active:-unknown}"
  else
    log "watching login1 sessions; no graphical session for $USER yet"
  fi

  # gdbus monitor lines look like:
  #   /org/freedesktop/login1/session/_33: org.freedesktop.DBus.Properties.PropertiesChanged ('org.freedesktop.login1.Session', {'Active': <true>}, @as [])
  gdbus monitor --system --dest org.freedesktop.login1 |
    while IFS= read -r line; do
      case "$line" in
        /org/freedesktop/login1/session/*:*"'Active'"*"<true>"*) active="true" ;;
        /org/freedesktop/login1/session/*:*"'Active'"*"<false>"*) active="false" ;;
        *) continue ;;
      esac

      path="${line%%:*}"
      is_own_graphical_session "$path" || continue

      if [[ "${prev_active_by_path[$path]:-false}" == "false" && "$active" == "true" ]]; then
        log "session $path became active -> dpms on"
        wake_hypr
      fi
      prev_active_by_path["$path"]="$active"
    done
}

main "$@"
